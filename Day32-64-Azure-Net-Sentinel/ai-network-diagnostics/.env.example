# Copy to .env and set values. Do not commit .env.

# ---------------------------------------------------------------------------
# Required for LLM reasoning (otherwise report is built from retrieved context only)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here

# ---------------------------------------------------------------------------
# Optional: override default model names
# ---------------------------------------------------------------------------
# OPENAI_CHAT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# Optional: paths (relative to ai-network-diagnostics directory)
# ---------------------------------------------------------------------------
# TELEMETRY_PATH=telemetry/telemetry_events.json
# HISTORICAL_INCIDENTS_PATH=knowledge_base/historical_incidents.json
# RUNBOOKS_PATH=knowledge_base/runbooks.json
# VECTOR_DB_DIR=vector_db

# ---------------------------------------------------------------------------
# Optional: retrieval and thresholds
# ---------------------------------------------------------------------------
# TOP_K_INCIDENTS=5
# TOP_K_RUNBOOKS=5
# THRESHOLD_LATENCY_MS=100
# THRESHOLD_PACKET_LOSS_PCT=2
# THRESHOLD_QUEUE_DEPTH_PCT=80

# ---------------------------------------------------------------------------
# Optional: logging
# ---------------------------------------------------------------------------
# LOG_LEVEL=INFO
